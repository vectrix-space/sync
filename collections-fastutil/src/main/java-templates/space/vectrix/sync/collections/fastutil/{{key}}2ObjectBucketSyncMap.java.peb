   * @param table the node array
   * @param index the index
   * @param node the node
   */
  private static void setNode(final Node[] table, final int index, final @Nullable Node node) {
    {{ key }}2ObjectBucketSyncMap.NODE_ARRAY.setRelease(table, index, node);
  }


  private final class EntryIterator extends Traverser implements ObjectIterator<{{ key }}2ObjectMap.Entry<V>> {
    private {{ key }}2ObjectMap.@Nullable Entry<V> next;
    private {{ key }}2ObjectMap.@Nullable Entry<V> current;


   *
   * @param table the node array
   * @param index the index
   * @return the node, or null
   */
  private static @Nullable Node getNode(final Node[] table, final int index) {
    return (Node) {{ key }}2ObjectBucketSyncMap.NODE_ARRAY.getAcquire(table, index);
  }

  /**
   * Atomically compare and swaps the {@link Node} at the given {@code index}
   * from the {@code oldNode} to the {@code newNode}.
   *
   * @param table    the node array
   * @param index    the index
   * @param nextNode the new node
   * @return true if new node was set, otherwise false
   */
  private static boolean replaceNode(final Node[] table, final int index, final @Nullable Node nextNode) {
    return {{ key }}2ObjectBucketSyncMap.NODE_ARRAY.compareAndExchangeRelease(table, index, (Node) null, nextNode) == null;
  }

  /**
   * Sets the given {@link Node} at the given {@code index}.

  protected static final class ForwardingNode extends Node {
    private transient final Node[] nextTable;

    private ForwardingNode(final Node[] nextTable) {
      super({{ key }}2ObjectBucketSyncMap.NODE_MOVED, ({{ keyPrimitive }}) 0, null);

      this.nextTable = nextTable;
